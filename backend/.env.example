# Environment Variables Example Configuration
PORT=8080

# Database Configuration
DB_DSN=postgres://postgres:password@localhost:5432/mi-tech?sslmode=disable

# Security Configuration
ALLOWED_ORIGINS=http://localhost:5173,https://mi-tech.millennialperfumer.in
JWT_SECRET=your-secret-key-here

# Amazon SP-API Configuration
AMAZON_LWA_CLIENT_ID=your-lwa-client-id
AMAZON_LWA_CLIENT_SECRET=your-lwa-client-secret
AMAZON_LWA_REFRESH_TOKEN=your-lwa-refresh-token
AMAZON_AWS_ACCESS_KEY=your-aws-access-key
AMAZON_AWS_SECRET_KEY=your-aws-secret-key
AMAZON_AWS_REGION=us-east-1
AMAZON_MARKETPLACE_ID=your-marketplace-id
AMAZON_SELLER_ID=your-seller-id
